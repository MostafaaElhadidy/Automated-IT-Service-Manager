# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Package manager lock files (requirements.txt is the source of truth)
uv.lock

# Virtual environment
.venv/
venv/
env/

# Environment variables — never commit secrets
.env
.env.local

# Vector DB — generated by `make ingest`, not source
data/chroma/

# MeshCentral runtime data (certs, db) — generated at runtime, contains secrets
meshcentral-data/
meshcentral-files/

# Logs
*.log

# Chainlit runtime files and auto-generated translations
.files/
.chainlit/translations/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
