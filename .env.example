# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# Named SYNAPSE_* so Chainlit's data layer doesn't pick up DATABASE_URL
SYNAPSE_DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse
SYNAPSE_DATABASE_URL_RO=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse

# ── Backend ───────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ── LLM providers ─────────────────────────────────────────────────────────────
# Use one of: Groq (free), Gemini (free), or Ollama (local)
GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Per-agent model routing ───────────────────────────────────────────────────
SUPERVISOR_MODEL=groq/llama-3.3-70b-versatile
INTAKE_MODEL=groq/llama-3.3-70b-versatile
RCA_MODEL=groq/llama-3.3-70b-versatile
REMEDIATION_MODEL=groq/llama-3.3-70b-versatile

# ── MCP servers ───────────────────────────────────────────────────────────────
RUNBOOK_MCP_URL=http://localhost:9001
SEQ_THINKING_CMD=npx -y @modelcontextprotocol/server-sequential-thinking

# ── Vector store ──────────────────────────────────────────────────────────────
CHROMA_DIR=./data/chroma

# ── Fast-path / determinism ───────────────────────────────────────────────────
FASTPATH_THRESHOLD=0.75
SIM_SEED=42

# ── Tracing (optional — leave blank to disable) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Email alerts via Resend (free — https://resend.com) ──────────────────────
# Free tier "from" must be: onboarding@resend.dev
RESEND_API_KEY=
ALERT_EMAIL_TO=your-email@example.com
ALERT_EMAIL_FROM=SynapseITSM <onboarding@resend.dev>
DASHBOARD_URL=http://localhost:8502

# ── MeshCentral — remote endpoint remediation ────────────────────────────────
# Start MeshCentral: docker compose --profile meshcentral up -d
# Then open https://localhost:8443 → create admin account → create device group
# "SynapseITSM-Endpoints" → generate login key: node meshcentral --logintokenkey
MESHCENTRAL_ENABLED=false
MESHCENTRAL_URL=wss://localhost:8443/control.ashx
MESHCENTRAL_USER=synapse-bot
MESHCENTRAL_PASSWORD=
MESHCENTRAL_LOGINKEY=            # preferred over password — from --logintokenkey
MESHCENTRAL_DEVICE_GROUP=SynapseITSM-Endpoints
MESHCENTRAL_VERIFY_TLS=false     # set true in prod with a real TLS cert
MESHCENTRAL_MESHCTRL=meshctrl    # path to meshctrl CLI (npm install -g meshcentral)

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Change JWT_SECRET to a long random string before deploying
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_MINUTES=480
# Required by Chainlit password auth (any random string)
CHAINLIT_AUTH_SECRET=change-me-to-a-long-random-string


